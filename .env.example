# KubeForge Core — Environment Variables
# Copy this file to .env and fill in your values

APP_NAME=KubeForge Security Platform
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

API_HOST=0.0.0.0
API_PORT=8080
API_SECRET_KEY=change-me-in-production

# AI Co-Pilot
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o
COPILOT_LANGUAGE=hebrew

# Scanner
SCAN_INTERVAL_SECONDS=60
SCAN_TARGET_PATHS=["/data","/tmp"]
MAX_FILE_SIZE_MB=50

# Alerts (optional)
ALERT_EMAIL=
SLACK_WEBHOOK_URL=
